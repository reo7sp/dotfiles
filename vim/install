#!/bin/bash
set -e -o pipefail

key=$1
if [[ $key == "-q" ]]; then
  QUICK_INSTALL=1
else
  QUICK_INSTALL=0
fi

confirm() {
  local message=$1

  if [[ $QUICK_INSTALL == 1 ]]; then
    false
  else
    echo -n -e "${BWhite}$message${Color_Off} [y/N] "
    read response
    case $response in
      [yY][eE][sS]|[yY])
        true
        ;;
      *)
        false
        ;;
    esac
  fi
}


mkdir -p ~/.config/nvim/{lua/plugins,lua/fixes,lua/commands,lua/configs,after/syntax,after/ftplugin,bin}
cp nvim/init.lua ~/.config/nvim/init.lua
cp nvim/lazy-lock.json ~/.config/nvim/lazy-lock.json
cp nvim/lua/plugins.lua ~/.config/nvim/lua/plugins.lua
cp nvim/lua/plugins/appearance.lua ~/.config/nvim/lua/plugins/appearance.lua
cp nvim/lua/plugins/commands.lua ~/.config/nvim/lua/plugins/commands.lua
cp nvim/lua/plugins/editor.lua ~/.config/nvim/lua/plugins/editor.lua
cp nvim/lua/plugins/file_management.lua ~/.config/nvim/lua/plugins/file_management.lua
cp nvim/lua/plugins/general.lua ~/.config/nvim/lua/plugins/general.lua
cp nvim/lua/plugins/languages.lua ~/.config/nvim/lua/plugins/languages.lua
cp nvim/lua/plugins/navigation.lua ~/.config/nvim/lua/plugins/navigation.lua
cp nvim/lua/fixes/async.lua ~/.config/nvim/lua/fixes/async.lua
cp nvim/lua/commands.lua ~/.config/nvim/lua/commands.lua
cp nvim/lua/settings.lua ~/.config/nvim/lua/settings.lua
cp nvim/after/syntax/vim.vim ~/.config/nvim/after/syntax/vim.vim
cp nvim/after/ftplugin/jinja.vim ~/.config/nvim/after/ftplugin/jinja.vim
cp ideavimrc ~/.ideavimrc
cp vscodevimrc ~/.vscodevimrc
cp neovintageousrc ~/.neovintageousrc
if [ -f ~/.config/nvim/lua/plugins/custom.lua ]; then
  if confirm "Do you want to overwrite ~/.config/nvim/lua/plugins/custom.lua?"; then
    cp nvim/lua/plugins/custom.lua ~/.config/nvim/lua/plugins/custom.lua
  fi
else
  cp nvim/lua/plugins/custom.lua ~/.config/nvim/lua/plugins/custom.lua
fi
if [ -f ~/.config/nvim/lua/commands/custom.lua ]; then
  if confirm "Do you want to overwrite ~/.config/nvim/lua/commands/custom.lua?"; then
    cp nvim/lua/commands/custom.lua ~/.config/nvim/lua/commands/custom.lua
  fi
else
  cp nvim/lua/commands/custom.lua ~/.config/nvim/lua/commands/custom.lua
fi
if [ -f ~/.config/nvim/bin/custom-gopls ]; then
  if confirm "Do you want to overwrite ~/.config/nvim/bin/custom-gopls?"; then
    cp nvim/bin/custom-gopls ~/.config/nvim/bin/custom-gopls
    chmod +x ~/.config/nvim/bin/custom-gopls
  fi
else
  cp nvim/bin/custom-gopls ~/.config/nvim/bin/custom-gopls
  chmod +x ~/.config/nvim/bin/custom-gopls
fi
if [ -f ~/.config/nvim/lua/configs/custom_minuet_llm.lua ]; then
  if confirm "Do you want to overwrite custom_minuet_llm.lua?"; then
    cp nvim/lua/configs/custom_minuet_llm.lua ~/.config/nvim/lua/configs/custom_minuet_llm.lua
  fi
else
  cp nvim/lua/configs/custom_minuet_llm.lua ~/.config/nvim/lua/configs/custom_minuet_llm.lua
fi

nvim --headless "+Lazy! restore" +qa
